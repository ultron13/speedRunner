# Application
NODE_ENV=production
PORT=8787
WS_PORT=8788

# Database (PostgreSQL)
DATABASE_URL=postgresql://speedrunner:speedrunner_secret@postgres:5432/speedrunner

# Redis
REDIS_URL=redis://redis:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# API
API_KEY=your-api-key-here
CORS_ORIGIN=http://localhost:8787

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
