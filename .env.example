# SpeedRunner Enterprise Environment Configuration

# Database
DATABASE_URL=postgresql://speedrunner:speedrunner_secret@localhost:5432/speedrunner

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production

# Go Backend API URL (set to empty for standalone mode)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Kubernetes
K8S_IN_CLUSTER=false
K8S_EXECUTION_NS=marathonrunner-execution
K8S_SYSTEM_NS=marathonrunner-system
