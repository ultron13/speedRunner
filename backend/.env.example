# Server
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_URL=postgresql://speedrunner:speedrunner_secret@localhost:5432/speedrunner

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# Kubernetes
K8S_IN_CLUSTER=false
K8S_EXECUTION_NS=marathonrunner-execution
K8S_SYSTEM_NS=marathonrunner-system

# Engine
JMETER_IMAGE=apache/jmeter:5.6.3
DEFAULT_VUS=10
MAX_VUS=1000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
